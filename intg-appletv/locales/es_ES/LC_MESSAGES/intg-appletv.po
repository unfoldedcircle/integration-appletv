msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"
"Plural-Forms: nplurals=2; plural=n != 1;\n"
"Language: es_ES\n"

msgid "Action"
msgstr "Acción"

msgid "Add a new device"
msgstr "Añadir nuevo dispositivo"

msgid "Apple TV 4 and newer are supported and the device must be on the same network as the remote."
msgstr "Apple TV 4 y más recientes son compatibles y debe estar en la misma red que el mando a distancia."

msgid "Apple TV AirPlay-Code"
msgstr "Código AirPlay de Apple TV"

msgid "Apple TV PIN"
msgstr "PIN de Apple TV"

msgid "Change volume on all connected devices"
msgstr "Cambia el volumen en todos los dispositivos conectados"

msgid "Choose your Apple TV"
msgstr "Elige tu Apple TV"

msgid "Configuration mode"
msgstr "Tipo de configuración"

msgid "Configure selected device"
msgstr "Configurar dispositivo seleccionado"

msgid "Configured devices"
msgstr "Dispositivos configurados"

msgid "Control your Apple TV with Remote Two/3."
msgstr "Controla tu Apple TV con el Remote Two/3."

msgid "Delete selected device"
msgstr "Eliminar dispositivo seleccionado"

msgid "Discover or connect to Apple TV device"
msgstr "Descubre o conecta con el dispositivo Apple TV"

msgid "During the process, you need to enter multiple PINs that are shown on your Apple TV. Please make sure to set AirPlay access to _Anyone on the Same Network_ in Apple TV settings."
msgstr "Durante el proceso, necesitas ingresar múltiples PIN que se muestran en tu Apple TV. Por favor, asegúrate de configurar el acceso de AirPlay de la siguiente manera Cualquiera en la misma red en la configuración de Apple TV."

msgid "Integration setup"
msgstr "Configuración de la integración"

msgid "IP address (optional)"
msgstr "Direccion IP (opcional)"

msgid "IP address (same network only)"
msgstr "Dirección IP (solo de la misma red)"

# Translators: Markdown can be used for formatting
msgid "Leave blank to use auto-discovery and click _Next_."
msgstr "Deje en blanco para usar auto-discovery y haga click en _Siguiente_."

msgid "MAC address"
msgstr "MAC adress"

msgid "Manual MAC address"
msgstr "Direccion MAC manual"

msgid "Manual MAC address (below)"
msgstr "Direccion MAC manual (abajo)"

msgid "Please choose your Apple TV"
msgstr "Por favor, elige tu Apple TV"

msgid "Please enter the shown AirPlay-Code on your Apple TV"
msgstr "Por favor, introduce el código AirPlay mostrado en tu Apple TV"

msgid "Please enter the shown PIN on your Apple TV"
msgstr "Por favor, introduce el PIN mostrado en tu Apple TV"

# Translators: Make sure to include the support article link as Markdown. See English text
msgid "Please see our support article for requirements, features and restrictions."
msgstr "Por favor, consulta nuestro [artículo de soporte] (https://support.unfoldedcircle.com/hc/es/articles/19479576638620) para los requisitos, características y restricciones."

msgid "Reset configuration and reconfigure"
msgstr "Restablecer configuración y reconfigurar"

msgid "Setup mode"
msgstr "Modo de configuración"

msgid "Setup process"
msgstr "Proceso de configuración"

msgid "The device must be on the same network as the remote."
msgstr "El dispositivo debe estar en la misma red que el mando a distancia."

msgid "The integration will discover your Apple TV on your network."
msgstr "La integración detectará tu Apple TV en tu red."
